# Example .env file (do NOT commit real secrets)
# Copy this file to .env and fill values locally or set them in Render Environment

# Cloudinary
CLOUDINARY_API_SECRET=<YOUR_CLOUDINARY_API_SECRET>
CLOUDINARY_CLOUD_NAME=<YOUR_CLOUDINARY_CLOUD_NAME>
CLOUDINARY_URL=<YOUR_CLOUDINARY_URL>

# Email (Gmail)
EMAIL_USER=<your_email@example.com>
EMAIL_PASS=<your_email_app_password>

# Firebase service account JSON (either set the full JSON in FIREBASE_SERVICE_ACCOUNT or upload file and set FIREBASE_SERVICE_ACCOUNT_PATH)
FIREBASE_SERVICE_ACCOUNT=<FULL_JSON_OR_LEAVE_EMPTY>
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase/service-account.json

# Hugging Face token (if used)
HF_TOKEN=<your_hf_token>

# JWT secrets
JWT_REFRESH_SECRET=<your_jwt_refresh_secret>
JWT_SECRET=<your_jwt_secret>

# MongoDB (Atlas)
MONGO_CLUSTER=<your_cluster_identifier>
MONGO_DB_NAME=<your_db_name>
MONGO_USER=<your_db_user>
MONGO_PASSWORD=<your_db_password>
MONGO_URI=mongodb+srv://<user>:<encoded_password>@<cluster>/dbname?retryWrites=true&w=majority

# Optional: force DNS servers for SRV resolution
MONGO_DNS_SERVERS=8.8.8.8,1.1.1.1

# Optional fallback (non-SRV) - use only if SRV fails
# MONGO_URI_FALLBACK=mongodb://<DB_USER>:<ENCODED_PASSWORD>@host1:27017,host2:27017/<DB_NAME>?replicaSet=...&authSource=admin&ssl=true

# Server
PORT=5000

# App keys
PRIVATE_KEY=<random-private-key>
PUBLIC_KEY=<public-key>

# Third-party keys
TAVILY_API_KEY=<your_tavily_api_key>

# NOTES:
# - Do NOT commit real secrets to the repository. Use Render UI to set production variables.
# - If you suspect secrets have been exposed, rotate/revoke them immediately.
# =====================================
# 🔧 CONFIGURATION BACKEND API
# =====================================

# API Tavily (Recherche Web)
TAVILY_API_KEY=your_tavily_api_key_here

# Serveur Backend
HOST=0.0.0.0
PORT=8001

# Base de données (si utilisée)
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# JWT Secret (si authentification)
# JWT_SECRET=your_secret_key_here

# Environnement
NODE_ENV=development

# =====================================
# 🤖 CHEMINS DES MODÈLES IA
# =====================================

# Modèle SmolVLM (Vision)
SMOLVLM_MODEL_PATH=./models/smolvlm/cache

# Modèle Mistral (LLM)
MISTRAL_MODEL_PATH=./models/mistral/mistral-7b-instruct-v0.2.Q4_K_M.gguf

# Modèle YOLO (Détection)
YOLO_MODEL_PATH=./models/lifemodo_tfjs

# TTS (Text-to-Speech)
TTS_MODEL_PATH=./models/tts_env

# =====================================
# 📊 CONFIGURATION RAG / FAISS
# =====================================

# Dimension des embeddings
EMBEDDING_DIMENSION=384

# Stockage FAISS
FAISS_STORAGE_PATH=./storage/chat_memory

# =====================================
# 🎥 CONFIGURATION OPTIONNELLE
# =====================================

# Max upload size (en MB)
MAX_UPLOAD_SIZE=50

# Timeout pour les requêtes (en secondes)
REQUEST_TIMEOUT=120
